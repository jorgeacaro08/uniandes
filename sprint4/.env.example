# Copie a .env y ajuste. Usado por docker-compose y los despliegues.

# PostgreSQL - Alertas / costos crudos (ms-alertas)
ALERTAS_DB_HOST=postgres-alertas
ALERTAS_DB_NAME=alertas_db
ALERTAS_DB_USER=monitoring_user
ALERTAS_DB_PASSWORD=isis2503

# PostgreSQL - Autenticacion (ms-autenticacion)
AUTH_DB_HOST=postgres-auth
AUTH_DB_NAME=auth_db
AUTH_DB_USER=monitoring_user
AUTH_DB_PASSWORD=isis2503

# MongoDB - consolidados (ms-alertas escribe, ms-reportes lee)
MONGO_URI=mongodb://monitoring_user:isis2503@mongo:27017/?authSource=admin
MONGO_DB=reportes_db
MONGO_COLLECTION=reportes_consolidados

# Seguridad (ms-reportes)
AUTH_ENABLED=true
AUTH_PROVIDER=local
AUTH_SECRET=dev-secret
# Produccion con Auth0:
# AUTH_PROVIDER=auth0
# AUTH0_DOMAIN=tu-tenant.us.auth0.com
# AUTH0_AUDIENCE=https://api.bite.co/reportes
